<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View Blog</title>
    <link rel="stylesheet" href="/style2.css">
</head>
<body>


    <h1>Here is your Blog</h1>

    <div class="blog">
     <div class="blog-content">
     
    <div class="i">
    <img  src="<%= blog.userimg %>" alt="">

    <div class="id">
    <span class="s"> @<%= blog.username %> </span>
    
    <span > @<%= blog.id %> </span>
    </div>

</div>

    <img  src="<%= blog.image %>" alt="">


    <div class="text">
    <h3><%= blog.title %></h3>
    <p>
        <form class="edit" method="post" action="/blogs/<%= blog.id %>?_method=PATCH">
            <textarea  row="20" cols="30" name="content" ><%= blog.content %></textarea>
            <button  class="btn" type="submit">Submit</button>
        </form>
    
    </p>

    </div>

    <div class="link">
    

    </div>



    </div>

    </div>

</body>
</html>